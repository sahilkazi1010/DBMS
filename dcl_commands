==================================================
                TCL COMMANDS
==================================================

--------------------------------------------------
-- CREATE TABLE
--------------------------------------------------

CREATE TABLE student (
    id INT,
    name VARCHAR(20),
    marks INT,
    result VARCHAR(10)
);

--------------------------------------------------
-- INSERT VALUES
--------------------------------------------------

INSERT INTO student VALUES
(1, 'Sahil', 78, 'pass'),
(2, 'Umar', 25, 'fail'),
(3, 'Nazir', 90, 'pass'),
(4, 'Afan', 30, 'fail'),
(5, 'Saheem', 65, 'pass');

--------------------------------------------------
-- VIEW TABLE
--------------------------------------------------

SELECT * FROM student;

--------------------------------------------------
-- DISABLE AUTOCOMMIT
--------------------------------------------------

SET AUTOCOMMIT = 0;

--------------------------------------------------
-- START TRANSACTION
--------------------------------------------------

START TRANSACTION;

--------------------------------------------------
-- INSERT NEW RECORDS
--------------------------------------------------

INSERT INTO student VALUES
(6, 'Rahul', 85, 'pass');

INSERT INTO student VALUES
(7, 'Aman', 20, 'fail');

--------------------------------------------------
-- CREATE SAVEPOINT
--------------------------------------------------

SAVEPOINT a;

--------------------------------------------------
-- DELETE RECORD
--------------------------------------------------

DELETE FROM student
WHERE id = 5;

--------------------------------------------------
-- VIEW TABLE AFTER DELETE
--------------------------------------------------

SELECT * FROM student;

--------------------------------------------------
-- ROLLBACK TO SAVEPOINT
--------------------------------------------------

ROLLBACK TO a;

--------------------------------------------------
-- VIEW TABLE AFTER ROLLBACK
--------------------------------------------------

SELECT * FROM student;

--------------------------------------------------
-- SAVE CHANGES
--------------------------------------------------

COMMIT;
