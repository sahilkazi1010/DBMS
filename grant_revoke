==================================================
                DCL COMMANDS
==================================================

--------------------------------------------------
-- DISPLAY CURRENT USER
--------------------------------------------------

SELECT USER();

--------------------------------------------------
-- CREATE NEW USER
--------------------------------------------------

CREATE USER 'sahi'@'localhost'
IDENTIFIED BY '45';

--------------------------------------------------
-- VIEW USER PERMISSIONS
--------------------------------------------------

SHOW GRANTS FOR 'sahi'@'localhost';

--------------------------------------------------
-- GRANT PERMISSIONS
--------------------------------------------------

GRANT SELECT, UPDATE
ON student
TO 'sahi'@'localhost';

--------------------------------------------------
-- VIEW UPDATED PERMISSIONS
--------------------------------------------------

SHOW GRANTS FOR 'sahi'@'localhost';

--------------------------------------------------
-- REVOKE PERMISSION
--------------------------------------------------

REVOKE UPDATE
ON student
FROM 'sahi'@'localhost';

--------------------------------------------------
-- VIEW PERMISSIONS AFTER REVOKE
--------------------------------------------------

SHOW GRANTS FOR 'sahi'@'localhost';
