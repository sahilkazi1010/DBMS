
--------------------------------------------------
-- CREATE DATABASE
--------------------------------------------------

CREATE DATABASE college;

USE college;

--------------------------------------------------
-- CREATE TABLES
--------------------------------------------------

CREATE TABLE student (
    id INT,
    name VARCHAR(20)
);

CREATE TABLE course (
    id INT,
    course VARCHAR(20)
);

--------------------------------------------------
-- INSERT VALUES
--------------------------------------------------

INSERT INTO student VALUES
(1, 'Rahul'),
(2, 'Aman'),
(3, 'Priya');

INSERT INTO course VALUES
(1, 'DBMS'),
(2, 'Java'),
(4, 'Python');

--------------------------------------------------
-- VIEW TABLES
--------------------------------------------------

SELECT * FROM student;

SELECT * FROM course;

==================================================
                JOIN OPERATIONS
==================================================

--------------------------------------------------
-- INNER JOIN
--------------------------------------------------

SELECT *
FROM student
INNER JOIN course
ON student.id = course.id;

--------------------------------------------------
-- LEFT JOIN
--------------------------------------------------

SELECT *
FROM student
LEFT JOIN course
ON student.id = course.id;

--------------------------------------------------
-- RIGHT JOIN
--------------------------------------------------

SELECT *
FROM student
RIGHT JOIN course
ON student.id = course.id;

--------------------------------------------------
-- NATURAL JOIN
--------------------------------------------------

SELECT *
FROM student
NATURAL JOIN course;

--------------------------------------------------
-- FULL OUTER JOIN
--------------------------------------------------

SELECT *
FROM student
LEFT JOIN course
ON student.id = course.id

UNION

SELECT *
FROM student
RIGHT JOIN course
ON student.id = course.id;

==================================================
                SET OPERATIONS
==================================================

--------------------------------------------------
-- UNION
--------------------------------------------------

SELECT id FROM student
UNION
SELECT id FROM course;

--------------------------------------------------
-- INTERSECT
--------------------------------------------------

SELECT id FROM student
INTERSECT
SELECT id FROM course;

--------------------------------------------------
-- EXCEPT
--------------------------------------------------

SELECT id FROM student
EXCEPT
SELECT id FROM course;
