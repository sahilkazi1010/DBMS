--------------------------------------------------
-- CREATE DATABASE
--------------------------------------------------

CREATE DATABASE college;

USE college;

--------------------------------------------------
-- CREATE TABLE
--------------------------------------------------

CREATE TABLE student (
    id INT,
    name VARCHAR(20),
    marks INT
);

--------------------------------------------------
-- INSERT VALUES
--------------------------------------------------

INSERT INTO student VALUES
(1, 'Rahul', 85),
(2, 'Aman', 70),
(3, 'Priya', 90);

--------------------------------------------------
-- VIEW TABLE
--------------------------------------------------

SELECT * FROM student;

==================================================
                    VIEW
==================================================

--------------------------------------------------
-- CREATE VIEW
--------------------------------------------------

CREATE VIEW student_view AS
SELECT name, marks
FROM student;

--------------------------------------------------
-- DISPLAY VIEW
--------------------------------------------------

SELECT * FROM student_view;

==================================================
                UPDATE VIEW
==================================================

--------------------------------------------------
-- UPDATE DATA THROUGH VIEW
--------------------------------------------------

UPDATE student_view
SET marks = 95
WHERE name = 'Priya';

--------------------------------------------------
-- DISPLAY UPDATED VIEW
--------------------------------------------------

SELECT * FROM student_view;

==================================================
                DELETE DATA FROM VIEW
==================================================

--------------------------------------------------
-- DELETE RECORD WHERE MARKS = 95
--------------------------------------------------

DELETE FROM student_view
WHERE marks = 95;

--------------------------------------------------
-- DISPLAY VIEW AFTER DELETE
--------------------------------------------------

SELECT * FROM student_view;

==================================================
                DROP VIEW
==================================================

DROP VIEW student_view;
